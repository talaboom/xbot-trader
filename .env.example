# X Bot Trader — Environment Variables
# Copy to .env and fill in values

# ── Database (Railway provides these) ──
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:password@host:5432/dbname

# ── Redis (Railway provides this) ──
REDIS_URL=redis://:password@host:6379/0

# ── Security (generate strong random values) ──
SECRET_KEY=change-me-to-a-random-64-character-string
ENCRYPTION_MASTER_KEY=change-me-to-a-base64-encoded-32-byte-key

# ── CORS (comma-separated allowed origins) ──
ALLOWED_ORIGINS=http://localhost:3000

# ── For production (xbottrader.ca) ──
# ALLOWED_ORIGINS=https://xbottrader.ca,https://www.xbottrader.ca

# ── Frontend (set in Railway frontend service) ──
# VITE_API_URL=https://your-backend-service.railway.app/api/v1

# ── AI Assistant (set ONE of these — DeepSeek is cheaper) ──
# DEEPSEEK_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-api03-...
# GEMINI_API_KEY=...

# ── Antigravity (OpenAI-compatible proxy/gateway, optional) ──
# Set BASE_URL to your self-hosted antigravity-claude-proxy or any
# OpenAI-compatible endpoint. Leave unset to disable this provider.
# ANTIGRAVITY_BASE_URL=http://localhost:8787/v1
# ANTIGRAVITY_API_KEY=...
# ANTIGRAVITY_MODEL=claude-sonnet-4.5

# ── OAuth Social Login ──
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# MICROSOFT_CLIENT_ID=your-microsoft-app-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret
# FRONTEND_URL=https://www.xbottrader.ca

# ── Telegram Bot ──
# TELEGRAM_BOT_TOKEN=1234567890:AABBccDDeeFFggHH
# TELEGRAM_CHANNEL_URL=https://t.me/xbottrader

# ── Optional ──
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
