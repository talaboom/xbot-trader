# API Plus Configuration
API_PLUS_URL=http://192.168.1.100:8000

# System Identification
SYSTEM_NAME=ParrotOS Laptop
SYSTEM_HOSTNAME=parrot-laptop
OS_TYPE=parrot
IP_ADDRESS=192.168.1.50

# SSH Configuration (for executing commands on other systems)
SSH_USER=root
SSH_PORT=22
SSH_KEY_PATH=/home/user/.ssh/id_rsa

# Agent Configuration
HEARTBEAT_INTERVAL=30

# Health Check Configuration (optional)
# Monitor a service and auto-restart if it crashes
ENABLE_HEALTH_CHECK=true
HEALTH_CHECK_INTERVAL=14400  # 4 hours in seconds
# Either HTTP health check OR command check (or both)
HEALTH_CHECK_URL=http://localhost:8000/health
HEALTH_CHECK_COMMAND=systemctl is-active xbot-trader
# If health check fails, run this command to recover
RECOVERY_COMMAND=systemctl restart xbot-trader
# Send alerts to this webhook when service goes down/recovers
ALERT_WEBHOOK=https://your-alert-service.com/webhook

# This will be auto-filled after registration
# API_KEY=<generated-on-first-run>
